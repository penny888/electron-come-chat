# 依赖目录
node_modules/
src/frontend/node_modules/
src/backend/node_modules/

# 构建输出
src/frontend/dist/
src/frontend/.vite/
release/
dist/
out/

# 数据文件（SQLite 数据库、上传的临时文件）
data/*.db
data/*.db-journal
uploads/
*.sqlite
*.sqlite3

# 环境变量文件（包含 API Key、密钥等）
.env
.env.local
.env.*.local

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# 操作系统临时文件
.DS_Store
Thumbs.db
desktop.ini

# IDE 配置（根据你的编辑器可保留部分）
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Electron 打包临时文件
.electron-builder/
.cache/
*.tmp

# 打包后解压的临时文件
*.7z
*.zip
*.dmg
*.pkg

# 测试覆盖率
coverage/
.nyc_output/

# TypeScript 编译临时文件（如果直接输出 js）
*.tsbuildinfo

# 备份文件
*.bak
*.orig

# 系统特定
*.exe
*.dll
*.so
*.dylib