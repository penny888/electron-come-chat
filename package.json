{
  "name": "come-chat",
  "version": "1.0.0",
  "main": "src/main/main.js",
  "scripts": {
    "postinstall": "npm run install-backend && npm run install-frontend",
    "install-backend": "cd src/backend && npm install",
    "install-frontend": "cd src/frontend && npm install",
    "dev": "set NODE_ENV=development&& concurrently \"npm run dev-backend\" \"npm run dev-frontend\" \"npm run dev-electron\"",
    "dev-backend": "cd src/backend && npm run dev",
    "dev-frontend": "cd src/frontend && npm run dev",
    "dev-electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build-frontend && npm run build-electron",
    "build-frontend": "cd src/frontend && npm run build",
    "build-electron": "electron-builder",
    "start": "electron ."
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0",
    "@langchain/community": "^0.0.20",
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^0.0.14",
    "@langchain/textsplitters": "^1.0.1",
    "@zilliz/milvus2-sdk-node": "^2.3.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.1.0",
    "langchainhub": "^0.0.8",
    "mammoth": "^1.4.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "sqlite3": "^6.0.1",
    "uuid": "^9.0.1"
  }
}
